@model AltarWeb.Models.ViewModels.MiEvaluacionViewModel
@using AltarWeb.Models.ViewModels
@{
    Layout = "_Layout";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded panel-dark" style="border-bottom:2px solid #1f9d8a;">
        <h2 class="text-white m-0"><i class="fa-solid fa-square-poll-vertical me-2 text-warning"></i>Mi Evaluacion</h2>
        <a href="/Alumno/Dashboard" class="btn btn-outline-secondary">Dashboard</a>
    </div>

    @if (Model.Estado == EstadoEvaluacion.SinEquipo)
    {
        <div class="panel-dark p-5 text-center rounded">
            <p class="text-secondary fs-5">Aun no perteneces a un equipo en este periodo.</p>
            <a href="/Alumno/CrearEquipo" class="btn btn-success">Crear mi equipo</a>
        </div>
    }
    else if (Model.Estado == EstadoEvaluacion.PendienteEvaluacion)
    {
        <div class="panel-dark p-5 text-center rounded">
            <p class="text-white fs-5">Tu equipo <strong>@Model.NombreEquipo</strong> aun no ha sido evaluado.</p>
            <p class="text-secondary">Cuando un juez evalue tu altar, los resultados apareceran aqui.</p>
        </div>
    }
    else
    {
        <div class="panel-dark p-4 rounded mb-4 text-center">
            <h3 class="text-white">@Model.NombreEquipo</h3>
            <p class="text-secondary">@Model.NombreDifunto | @Model.TipoAltar | @Model.Niveles</p>
            <div class="display-2 fw-bold text-success">@Model.NotaFinal.ToString("F1")</div>
            <div class="text-secondary">Nota final</div>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="panel-dark p-4 rounded h-100">
                    <h5 class="text-warning">Tradicion</h5>
                    <p class="text-secondary">@Model.ElementosPresentes/10 elementos</p>
                    <div class="fs-2 text-white">@Model.NotaTradicionFinal.ToString("F1")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="panel-dark p-4 rounded h-100">
                    <h5 class="text-warning">Personalizacion</h5>
                    <p class="text-secondary">@Model.BonusTematicos bonus tematicos</p>
                    <div class="fs-2 text-white">@Model.NotaPersonalizacionFinal.ToString("F1")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="panel-dark p-4 rounded h-100">
                    <h5 class="text-warning">Estetica</h5>
                    <p class="text-secondary">Nota asignada</p>
                    <div class="fs-2 text-white">@Model.NotaEstetica.ToString("F1")</div>
                </div>
            </div>
        </div>

        @if (Model.PuedeDescargarConstancia)
        {
            <div class="text-center mt-4">
                <a href="/Alumno/DescargarMiConstancia/@Model.EvaluacionId" class="btn btn-success btn-lg">
                    Descargar mi constancia
                </a>
            </div>
        }
    }
</div>
