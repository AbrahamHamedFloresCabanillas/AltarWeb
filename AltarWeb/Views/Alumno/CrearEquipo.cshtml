@model AltarWeb.Models.ViewModels.CrearEquipoViewModel
@{
    Layout = "_Layout";
}

<style>
    .lista-dropdown { list-style:none; margin:0; padding:0; position:absolute; z-index:20; background:#151515; border:1px solid var(--color-borde); width:100%; max-height:240px; overflow:auto; }
    .lista-dropdown li { padding:10px 12px; cursor:pointer; color:#f5f5f5; border-bottom:1px solid rgba(255,255,255,.08); }
    .lista-dropdown li:hover { background:rgba(31,157,138,.18); }
    .chip-integrante { display:inline-flex; align-items:center; gap:8px; padding:8px 10px; margin:4px; background:rgba(31,157,138,.18); color:#fff; border:1px solid #1f9d8a; }
    .chip-integrante button { width:22px; height:22px; border:0; background:#dc3545; color:#fff; }
</style>

<div class="container py-5" style="max-width: 820px;">
    <div class="panel-dark p-4 rounded">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-white m-0"><i class="fa-solid fa-users me-2" style="color:#1f9d8a"></i>Crear Equipo</h2>
            <a href="/Alumno/Dashboard" class="btn btn-outline-secondary btn-sm">Dashboard</a>
        </div>

        <form asp-action="CrearEquipo" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <div class="mb-4">
                <label asp-for="NombreEquipo" class="lbl-form"></label>
                <input asp-for="NombreEquipo" class="form-control form-control-dark" autocomplete="off" />
                <span asp-validation-for="NombreEquipo" class="text-danger small"></span>
            </div>

            <label class="lbl-form">Integrantes adicionales</label>
            <div class="campo-busqueda-integrante position-relative mb-3">
                <input type="text" id="buscarIntegrante" class="form-control form-control-dark"
                       placeholder="Buscar por nombre o matricula..." autocomplete="off" />
                <ul id="resultadosBusqueda" class="lista-dropdown" style="display:none;"></ul>
            </div>

            <div id="integrantesSeleccionados" class="mb-4"></div>

            <button type="submit" class="btn btn-success w-100 py-3 fw-bold">Guardar equipo</button>
        </form>
    </div>
</div>

<script>
document.getElementById('buscarIntegrante').addEventListener('input', async function () {
    const q = this.value.trim();
    const lista = document.getElementById('resultadosBusqueda');
    if (!q) { lista.style.display = 'none'; return; }

    const res = await fetch(`/Alumno/BuscarAlumno?q=${encodeURIComponent(q)}`);
    const data = await res.json();

    lista.innerHTML = '';
    if (data.length === 0) { lista.style.display = 'none'; return; }

    data.forEach(alumno => {
        const li = document.createElement('li');
        li.textContent = `${alumno.nombreCompleto} - ${alumno.matricula}`;
        li.addEventListener('click', () => agregarIntegrante(alumno));
        lista.appendChild(li);
    });
    lista.style.display = 'block';
});

function agregarIntegrante(alumno) {
    if (document.querySelector(`[data-integrante-id="${alumno.id}"]`)) return;

    const contenedor = document.getElementById('integrantesSeleccionados');
    const chip = document.createElement('div');
    chip.className = 'chip-integrante';
    chip.dataset.integranteId = alumno.id;
    chip.innerHTML = `
        <span>${alumno.nombreCompleto} (${alumno.matricula})</span>
        <input type="hidden" name="IntegranteIds" value="${alumno.id}" />
        <button type="button" aria-label="Quitar" onclick="this.parentElement.remove()">x</button>
    `;
    contenedor.appendChild(chip);
    document.getElementById('buscarIntegrante').value = '';
    document.getElementById('resultadosBusqueda').style.display = 'none';
}
</script>
