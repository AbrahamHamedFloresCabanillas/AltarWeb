@model AltarWeb.Models.ViewModels.CompletarRegistroGoogleViewModel
@{
    Layout = "_Layout";
}

<div class="container py-5" style="max-width: 640px;">
    <div class="panel-dark p-4 rounded" style="border-top: 4px solid #1f9d8a;">
        <h2 class="text-white mb-4"><i class="fa-brands fa-google me-2" style="color:#1f9d8a"></i>Completar Registro</h2>
        <form asp-action="CompletarRegistroGoogle" method="post">
            <div class="mb-3">
                <label asp-for="CorreoElectronico" class="lbl-form"></label>
                <input asp-for="CorreoElectronico" class="form-control form-control-dark" readonly />
            </div>
            <div class="mb-3">
                <label asp-for="NombreCompleto" class="lbl-form"></label>
                <input asp-for="NombreCompleto" class="form-control form-control-dark" readonly />
            </div>
            <div class="mb-4">
                <label asp-for="Matricula" class="lbl-form"></label>
                <input asp-for="Matricula" class="form-control form-control-dark" autocomplete="off" inputmode="numeric" />
                <span asp-validation-for="Matricula" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-success w-100 py-3 fw-bold">Guardar matricula</button>
        </form>
    </div>
</div>
