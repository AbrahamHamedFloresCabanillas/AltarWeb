@model IEnumerable<AltarWeb.Models.Evaluacion>
@{
    Layout = "_Layout";
}

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-info text-center m-0 fw-bold rounded-0">
        <i class="fa-solid fa-circle-info me-2"></i>@TempData["Mensaje"]
    </div>
}

<div style="height: 100vh; display: flex; flex-direction: column; padding: 20px;">

    <div class="d-flex justify-content-between align-items-center mb-3 p-3 rounded panel-dark" style="border-bottom: 2px solid var(--color-secundario);">
        <div class="d-flex align-items-center">
            <span style="font-size: 1.5rem; margin-right: 10px;">
                <i class="fa-solid fa-clock-rotate-left text-warning"></i>
            </span>
            <h2 class="text-white m-0">Historial de Evaluaciones</h2>
        </div>
        <div>
            <a href="/Evaluacion/Crear" class="btn btn-success btn-flat me-2 shadow-sm">
                <i class="fa-solid fa-plus me-1"></i> Nueva Evaluación
            </a>
            <a href="/Home/Menu" class="btn btn-danger btn-flat shadow-sm">
                <i class="fa-solid fa-arrow-left me-1"></i> Regresar
            </a>
        </div>
    </div>

    <div class="panel-dark p-4 d-flex flex-column flex-grow-1 overflow-hidden">
        <p class="text-silver mb-3 flex-shrink-0">
            <i class="fa-solid fa-circle-info text-primary me-1"></i>
            Haz <b>doble clic</b> para ver detalle o usa el botón <i class="fa-solid fa-paper-plane text-secondary"></i> para enviar resultados.
        </p>

        <div class="flex-grow-1 overflow-auto border-secondary">
            <table class="table-theme w-100">
                <thead style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th style="width: 25%;">Equipo</th>
                        <th style="width: 20%;">Difunto</th>
                        <th style="width: 15%;">Juez</th>
                        <th style="width: 10%;">Calif.</th>
                        <th style="width: 15%;">Fecha</th>
                        <th style="width: 15%; text-align: center;">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr ondblclick="verDetalle('@item.Id')">
                            <td><span class="text-orange fw-bold">@item.NombreEquipo</span></td>
                            <td><span class="text-white">@item.NombreDifunto</span></td>
                            <td><span class="text-secondary small fst-italic">@(item.Juez?.Usuario ?? "N/A")</span></td>
                            <td>
                                @if (item.NotaFinal >= 8.0m)
                                {
                                    <span class="grade-green">@item.NotaFinal.ToString("F1")</span>
                                }
                                else if (item.NotaFinal >= 6.0m)
                                {
                                    <span class="grade-yellow">@item.NotaFinal.ToString("F1")</span>
                                }
                                else
                                {
                                    <span class="grade-red">@item.NotaFinal.ToString("F1")</span>
                                }
                            </td>
                            <td class="text-silver">@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                <a href="/Evaluacion/Detalle/@item.Id" class="btn btn-primary btn-sm fw-bold px-2 shadow-sm me-1" title="Ver Detalle">
                                    <i class="fa-solid fa-eye me-1"></i> VER
                                </a>
                                <a href="/Evaluacion/EnviarResultados/@item.Id"
                                   class="btn btn-secondary btn-sm fw-bold px-2 shadow-sm"
                                   title="Enviar Resultados por Correo"
                                   onclick="return confirm('¿Enviar resultados y constancia a los integrantes de @item.NombreEquipo?')">
                                    <i class="fa-solid fa-paper-plane"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div class="p-5 text-center text-secondary fst-italic">No hay evaluaciones registradas aún.</div>
            }
        </div>
    </div>
</div>

<script>
    function verDetalle(id) { window.location.href = '/Evaluacion/Detalle/' + id; }
</script>