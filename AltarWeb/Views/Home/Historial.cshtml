@model IEnumerable<AltarWeb.Models.Evaluacion>
@{
    Layout = "_Layout";
}

<div class="d-flex flex-column" style="height: 100vh;">
    <div class="d-flex justify-content-between align-items-center p-3 flex-shrink-0" style="background-color: #1e1e1e; border-bottom: 1px solid white;">
        <h3 class="text-white fw-bold m-0">Historial de Evaluaciones</h3>
        <div>
            <a href="/Evaluacion/Crear" class="btn btn-green btn-flat me-2">+ NUEVA EVALUACIÓN</a>
            <a href="/Home/Menu" class="btn btn-red btn-flat">🔙 Regresar</a>
        </div>
    </div>

    <div class="p-4 flex-grow-1" style="background-color: #2d2d30;">
        <p class="text-silver fst-italic small mb-2">* Haz Doble Click en una fila para ver los detalles.</p>

        <div style="border: 1px solid #555; height: calc(100vh - 150px); overflow-y: auto;">
            <table class="table-theme mb-0">
                <thead style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th style="width: 50%;">Detalle Evaluación</th>
                        <th style="width: 20%;">Calificación</th>
                        <th style="width: 20%;">Fecha</th>
                        <th style="width: 10%; text-align: center;">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr ondblclick="window.location.href='/Evaluacion/Detalle/@item.Id'">
                            <td>
                                <span class="text-orange fw-bold">@item.NombreEquipo</span>
                                <span class="text-silver"> - @item.NombreDifunto - </span>
                                <span class="text-silver fst-italic small">(@(item.Juez?.Usuario))</span>
                            </td>
                            <td>
                                @if (item.NotaFinal >= 8.0m)
                                {
                                    <span class="grade-green fw-bold fs-5">@item.NotaFinal.ToString("F1")</span>
                                }
                                else if (item.NotaFinal >= 6.0m)
                                {
                                    <span class="grade-yellow fw-bold fs-5">@item.NotaFinal.ToString("F1")</span>
                                }
                                else
                                {
                                    <span class="grade-red fw-bold fs-5">@item.NotaFinal.ToString("F1")</span>
                                }
                            </td>
                            <td class="text-silver">@item.Fecha.ToString("g")</td>
                            <td style="text-align: center;">
                                <a href="/Evaluacion/Detalle/@item.Id" style="text-decoration: none; font-size: 1.2rem;">👁️</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!Model.Any())
            {
                <div class="p-5 text-center text-silver fst-italic" style="background-color: #333;">
                    No hay evaluaciones registradas aún.
                </div>
            }
        </div>
    </div>
</div>