@{
    ViewData["Title"] = "Menú Principal"; 
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Juez de Altares</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="~/css/paleta-de-colores.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="tema-oscuro">

    <div class="position-absolute top-0 end-0 m-3">
        <a href="/Acceso/Salir" class="text-secondary text-decoration-none small hover-white">
            <i class="fa-solid fa-right-from-bracket me-1"></i> Cerrar Sesión
        </a>
    </div>

    <div class="container d-flex flex-column align-items-center justify-content-center" style="height: 100vh;">
        <h1 class="text-white fw-bold mb-5" style="letter-spacing: 2px;">
            <i class="fa-solid fa-layer-group me-3 text-warning"></i>PANEL DE CONTROL
        </h1>

        <a href="/Evaluacion/Crear" class="btn btn-success mb-3 d-flex align-items-center justify-content-center shadow rounded-1"
           style="width: 450px; height: 80px; font-size: 1.5rem;">
            <i class="fa-solid fa-file-circle-plus me-3"></i> NUEVA EVALUACIÓN
        </a>

        <a href="/Home/Historial" class="btn btn-primary mb-4 d-flex align-items-center justify-content-center shadow rounded-1"
           style="width: 450px; height: 80px; font-size: 1.5rem;">
            <i class="fa-solid fa-clock-rotate-left me-3"></i> CONSULTAR HISTORIAL
        </a>

        <a href="/Constancia/Index" class="btn btn-secondary mb-5 shadow rounded-1 fw-bold"
           style="width: 300px; padding: 10px;">
            <i class="fa-solid fa-award me-2"></i> Generar Constancias
        </a>

        <div style="border-top: 1px solid var(--color-borde); width: 200px; margin-bottom: 20px;"></div>

        <a href="/Jueces/Index" class="btn btn-dark text-secondary btn-sm rounded-pill px-4 py-2">
            <i class="fa-solid fa-user-gear me-2"></i> Gestión de Jueces
        </a>

    </div>

    <!-- Logos Institucionales Lowkey -->
    <div class="logos-container">
        <img src="~/images/logo_uabc.png" alt="UABC" class="logo-img" />
        <img src="~/images/logo_fim.png" alt="FIM" class="logo-img" />
    </div>

</body>
</html>