@{
    ViewData["Title"] = "Menu Principal";
    ViewData["BodyClass"] = "menu-page";
    bool esAdmin = ViewBag.EsAdmin == true;
    string nombre = ViewBag.JuezNombre ?? "Usuario";
}

<main class="menu-shell">
    <header class="menu-topbar" aria-label="Sesion actual">
        <a class="menu-brand" href="/Home/Menu" aria-label="Ir al menu principal">
            <span class="menu-brand-mark">
                <i class="fa-solid fa-layer-group" aria-hidden="true"></i>
            </span>
            <span>
                <span class="menu-brand-title">Juez de Altares</span>
                <span class="menu-brand-subtitle">Panel institucional</span>
            </span>
        </a>

        <div class="menu-session">
            <span class="menu-user">
                <i class="fa-solid fa-user-circle" aria-hidden="true"></i>
                <span>@nombre</span>
            </span>
            <span class="menu-role @(esAdmin ? "is-admin" : "")">@(esAdmin ? "Admin" : "Juez")</span>
            <a href="/Acceso/Salir" class="menu-logout">
                <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i>
                <span>Cerrar sesion</span>
            </a>
        </div>
    </header>

    <section class="menu-workspace" aria-labelledby="menu-title">
        <div class="menu-copy">
            <p class="menu-kicker">Control de evaluaciones</p>
            <h1 id="menu-title">Panel de control</h1>
            <p class="menu-summary">Gestiona evaluaciones, historial y constancias desde un tablero claro para la jornada del concurso.</p>
        </div>

        <div class="menu-visual" aria-hidden="true">
            <img src="~/images/catrina.png" alt="" />
        </div>
    </section>

    <section class="menu-actions" aria-label="Acciones principales">
        <a href="/Evaluacion/Crear" class="menu-action menu-action-primary">
            <span class="menu-action-icon">
                <i class="fa-solid fa-file-circle-plus" aria-hidden="true"></i>
            </span>
            <span class="menu-action-body">
                <span class="menu-action-title">Nueva evaluacion</span>
                <span class="menu-action-text">Registrar puntuaciones y observaciones del altar.</span>
            </span>
            <i class="fa-solid fa-chevron-right menu-action-arrow" aria-hidden="true"></i>
        </a>

        <a href="/Home/Historial" class="menu-action">
            <span class="menu-action-icon is-blue">
                <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
            </span>
            <span class="menu-action-body">
                <span class="menu-action-title">Consultar historial</span>
                <span class="menu-action-text">Revisar evaluaciones guardadas por periodo.</span>
            </span>
            <i class="fa-solid fa-chevron-right menu-action-arrow" aria-hidden="true"></i>
        </a>

        <a href="/Constancia/Index" class="menu-action">
            <span class="menu-action-icon is-gold">
                <i class="fa-solid fa-award" aria-hidden="true"></i>
            </span>
            <span class="menu-action-body">
                <span class="menu-action-title">Constancias</span>
                <span class="menu-action-text">Generar documentos grupales o individuales.</span>
            </span>
            <i class="fa-solid fa-chevron-right menu-action-arrow" aria-hidden="true"></i>
        </a>
    </section>

    @if (esAdmin)
    {
        <section class="menu-admin" aria-labelledby="admin-title">
            <div class="menu-section-heading">
                <span class="menu-section-icon">
                    <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
                </span>
                <div>
                    <p class="menu-kicker">Administracion</p>
                    <h2 id="admin-title">Herramientas de sistema</h2>
                </div>
            </div>

            <div class="menu-admin-grid">
                <a href="/Jueces/Index" class="menu-admin-link">
                    <i class="fa-solid fa-user-gear" aria-hidden="true"></i>
                    <span>Jueces</span>
                </a>
                <a href="/Estudiantes/Index" class="menu-admin-link">
                    <i class="fa-solid fa-graduation-cap" aria-hidden="true"></i>
                    <span>Estudiantes historicos</span>
                </a>
                <a href="/Admin/Alumnos" class="menu-admin-link">
                    <i class="fa-solid fa-user-graduate" aria-hidden="true"></i>
                    <span>Alumnos</span>
                </a>
                <a href="/Admin/Equipos" class="menu-admin-link">
                    <i class="fa-solid fa-users" aria-hidden="true"></i>
                    <span>Equipos</span>
                </a>
            </div>
        </section>
    }
</main>
