@model AltarWeb.Models.Juez
@{
    Layout = "_Layout";
}

<div class="form-shell">

    <div class="p-5 shadow-lg rounded panel-dark">

        <h3 class="text-white form-title">
            <i class="fa-solid fa-user-plus me-2"></i>Nuevo Usuario
        </h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center fw-bold rounded-0 mb-4">
                <i class="fa-solid fa-circle-exclamation me-2"></i>@ViewBag.Error
            </div>
        }

        <form asp-action="Crear" method="post">
            <div class="mb-3">
                <label class="lbl-form mb-2 fw-bold">Nombre de Usuario:</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-user"></i></span>
                    <input asp-for="Usuario" class="form-control form-control-lg form-control-dark" required autocomplete="off" placeholder="Ej. profe_juan" />
                </div>
            </div>

            <div class="mb-3">
                <label class="lbl-form mb-2 fw-bold">Nombre Completo:</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-id-card"></i></span>
                    <input asp-for="NombreCompleto" class="form-control form-control-lg form-control-dark" autocomplete="off" placeholder="Ej. Juan Pérez García" />
                </div>
            </div>

            <div class="mb-3">
                <label class="lbl-form mb-2 fw-bold">Contraseña:</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-lock"></i></span>
                    <input asp-for="Password" type="password" class="form-control form-control-lg form-control-dark" required placeholder="••••••••" />
                </div>
            </div>

            <div class="mb-5">
                <label class="lbl-form mb-2 fw-bold">Rol:</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-secondary"><i class="fa-solid fa-shield-halved"></i></span>
                    <select asp-for="Rol" class="form-select form-control-dark">
                        <option value="Juez">Juez</option>
                        <option value="Admin">Administrador</option>
                    </select>
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-success btn-lg fw-bold shadow-sm">
                    <i class="fa-solid fa-floppy-disk me-2"></i>Guardar Usuario
                </button>
                <a href="/Jueces/Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
