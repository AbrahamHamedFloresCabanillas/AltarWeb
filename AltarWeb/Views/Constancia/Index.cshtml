@model IEnumerable<AltarWeb.Models.Evaluacion>
@{
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded panel-dark" style="border-bottom: 2px solid var(--color-secundario);">
        <h2 class="text-white m-0">
            <i class="fa-solid fa-file-signature me-2"></i>Generar Constancias
        </h2>
        <a href="/Home/Menu" class="btn btn-danger btn-flat shadow-sm">
            <i class="fa-solid fa-arrow-left me-1"></i> Regresar
        </a>
    </div>

    <div class="p-4 shadow-lg panel-dark">
        <p class="text-silver mb-3">
            <i class="fa-solid fa-circle-info text-primary me-1"></i>
            Haz <b>doble clic</b> en un equipo para descargar su constancia o usa el botón de descarga.
        </p>

        <div style="height: 500px; overflow-y: auto; border: 1px solid var(--color-borde);">
            <table class="table-theme w-100" id="tablaConstancias">
                <thead style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th style="width: 40%;"><i class="fa-solid fa-users me-2"></i>Equipo</th>
                        <th style="width: 30%;"><i class="fa-solid fa-cross me-2"></i>Difunto</th>
                        <th style="width: 15%;"><i class="fa-solid fa-calendar-days me-2"></i>Fecha</th>
                        <th style="width: 15%; text-align: center;">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr ondblclick="abrirPdf('@item.Id')">
                            <td class="text-orange fw-bold">@item.NombreEquipo</td>
                            <td class="text-white">@item.NombreDifunto</td>
                            <td class="text-silver">@item.Fecha.ToShortDateString()</td>
                            <td class="text-center">
                                <a href="/Constancia/Descargar/@item.Id"
                                   class="btn btn-success btn-sm fw-bold px-3 shadow-sm btn-pdf"
                                   target="_blank"
                                   title="Descargar PDF">
                                    <i class="fa-solid fa-file-pdf me-1"></i> PDF
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div class="p-5 text-center text-secondary fst-italic">
                    No hay evaluaciones disponibles para generar constancias.
                </div>
            }
        </div>
    </div>
</div>

<script>
    function abrirPdf(id) {
        const url = '/Constancia/Descargar/' + id;
        window.open(url, '_blank');
    }
</script>