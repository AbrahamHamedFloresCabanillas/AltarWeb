@model AltarWeb.Models.Evaluacion
@{
    Layout = "_Layout";
}

<style>
    .app-container { display:flex; flex-direction:column; min-height:100vh; padding:20px; box-sizing:border-box; }
    .panel-principal { display:flex; flex-direction:column; flex-grow:1; background-color:var(--color-superficie); border:1px solid var(--color-borde); overflow:hidden; }
    .tabs-header { background-color:var(--color-fondo); padding:10px 20px 0 20px; border-bottom:1px solid var(--color-borde); }
    .tab-pane { padding:20px; }
    .lista-dropdown { list-style:none; margin:0; padding:0; position:absolute; z-index:30; background:#151515; border:1px solid var(--color-borde); width:100%; max-height:260px; overflow:auto; }
    .lista-dropdown li { padding:10px 12px; cursor:pointer; color:#f5f5f5; border-bottom:1px solid rgba(255,255,255,.08); }
    .lista-dropdown li:hover { background:rgba(204,138,0,.15); }
    .integrante-item { padding:10px 12px; border-bottom:1px solid rgba(255,255,255,.08); color:#fff; }
</style>

<div class="app-container">
    <form id="mainForm" asp-action="Crear" method="post" novalidate>
        <div class="d-flex justify-content-between align-items-center mb-3 p-3 rounded panel-dark" style="border-bottom: 2px solid var(--color-secundario);">
            <h2 class="text-white m-0"><i class="fa-solid fa-pen-to-square me-2 text-warning"></i>Nueva Evaluacion</h2>
            <a href="/Home/Menu" class="btn btn-danger rounded-0 px-4 fw-bold" onclick="return confirm('Salir? Se perderan los datos.')">
                <i class="fa-solid fa-right-from-bracket me-1"></i> SALIR
            </a>
        </div>

        @if (TempData["Error"] != null || ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center fw-bold mb-3 shadow rounded-0">
                <i class="fa-solid fa-triangle-exclamation me-2"></i>@(TempData["Error"] ?? ViewBag.Error)
            </div>
        }

        <div class="panel-principal">
            <div class="tabs-header">
                <ul class="nav nav-tabs" id="myTab" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" id="equipo-tab" data-bs-toggle="tab" data-bs-target="#equipo" type="button">
                            <i class="fa-solid fa-users me-1"></i> 1. Equipo
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" id="altar-tab" data-bs-toggle="tab" data-bs-target="#altar" type="button">
                            <i class="fa-solid fa-star me-1"></i> 2. Evaluacion de Altar
                        </button>
                    </li>
                </ul>
            </div>

            <div class="tab-content" id="myTabContent">
                <div class="tab-pane fade show active" id="equipo">
                    <div class="campo-busqueda-equipo position-relative mb-3" style="max-width:720px;">
                        <label class="lbl-form text-warning fw-bold mb-1">Equipo a evaluar</label>
                        <input type="text" id="buscarEquipo" class="form-control form-control-dark rounded-0" placeholder="Escribe el nombre del equipo..." autocomplete="off" />
                        <input type="hidden" id="equipoSeleccionadoId" name="EquipoId" />
                        <ul id="resultadosEquipo" class="lista-dropdown" style="display:none;"></ul>
                    </div>

                    @if (ViewBag.EsAdmin == true)
                    {
                        <div class="form-check mt-2 mb-3">
                            <input class="form-check-input" type="checkbox" id="incluirHistorico" />
                            <label class="form-check-label text-secondary" for="incluirHistorico">
                                Mostrar equipos de periodos anteriores
                            </label>
                        </div>
                    }

                    <div id="integrantesEquipo" class="panel-dark p-3 rounded" style="display:none; max-width:720px;">
                        <h6 class="text-white"><i class="fa-solid fa-list me-2 text-warning"></i>Integrantes del equipo</h6>
                        <div id="listaIntegrantes"></div>
                    </div>
                </div>

                <div class="tab-pane fade" id="altar">
                    <div class="row g-4">
                        <div class="col-md-5">
                            <h5 class="text-white border-bottom border-secondary pb-2 mb-3"><i class="fa-solid fa-list-check me-2"></i>Datos Generales</h5>
                            <label class="text-secondary small">Difunto:</label>
                            <input asp-for="NombreDifunto" class="form-control form-control-dark mb-2" required autocomplete="off" />
                            <label class="text-secondary small">Niveles:</label>
                            <select asp-for="Niveles" class="form-select form-control-dark mb-2" required>
                                <option value="" selected disabled>-- Seleccionar --</option>
                                <option>2 Niveles</option>
                                <option>3 Niveles</option>
                                <option>7 Niveles</option>
                            </select>
                            <label class="text-secondary small">Tipo:</label>
                            <select asp-for="TipoAltar" class="form-select form-control-dark mb-4" required>
                                <option value="" selected disabled>-- Seleccionar --</option>
                                <option>Tradicional</option>
                                <option>Ninos</option>
                                <option>Mascotas</option>
                            </select>
                            <h5 class="text-white border-bottom border-secondary pb-2 mb-2"><i class="fa-solid fa-check-double me-2"></i>Checklist</h5>
                            <div class="p-2 rounded mb-3 bg-dark border-secondary">@await Html.PartialAsync("_ChecklistPartial", Model)</div>
                        </div>
                        <div class="col-md-7">
                            <h5 class="text-white border-bottom border-secondary pb-2 mb-3"><i class="fa-solid fa-calculator me-2"></i>Calificacion</h5>
                            <label class="text-secondary small">Hobbies / Tematica:</label>
                            <textarea asp-for="Hobbies" class="form-control form-control-dark mb-3" rows="8" required></textarea>
                            <div class="panel-dark p-3 rounded">
                                <div class="row mb-2"><div class="col-5"><label class="text-secondary">Tradicion (0-10):</label></div><div class="col-7"><input type="number" asp-for="NotaTradicion" class="form-control form-control-dark text-center fw-bold" step="0.1" min="0" max="10" /></div></div>
                                <div class="row mb-2"><div class="col-5"><label class="text-warning fw-bold">Personalizacion (0-10):</label></div><div class="col-7"><input type="number" asp-for="NotaPersonalizacion" class="form-control form-control-dark text-center fw-bold" step="0.1" min="0" max="10" /></div></div>
                                <div class="row mb-3"><div class="col-5"><label class="text-secondary">Estetica (0-10):</label></div><div class="col-7"><input type="number" asp-for="NotaEstetica" class="form-control form-control-dark text-center fw-bold" step="0.1" min="0" max="10" /></div></div>
                                <button type="submit" class="btn btn-primary w-100 py-3 fs-5 shadow fw-bold">
                                    <i class="fa-solid fa-floppy-disk me-2"></i>GUARDAR EVALUACION
                                </button>
                                <input type="hidden" asp-for="BonusTematicos" id="BonusTotal" value="0" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
document.getElementById('buscarEquipo').addEventListener('input', async function () {
    const q = this.value.trim();
    const historico = document.getElementById('incluirHistorico')?.checked ?? false;
    const lista = document.getElementById('resultadosEquipo');

    if (!q) {
        lista.style.display = 'none';
        limpiarIntegrantes();
        return;
    }

    const res = await fetch(`/Evaluacion/BuscarEquipos?q=${encodeURIComponent(q)}&incluirHistorico=${historico}`);
    const data = await res.json();

    lista.innerHTML = '';
    data.forEach(equipo => {
        const li = document.createElement('li');
        li.textContent = `${equipo.nombreEquipo} (${equipo.periodoAcademico}) - ${equipo.cantidadIntegrantes} integrante(s)`;
        li.addEventListener('click', () => seleccionarEquipo(equipo));
        lista.appendChild(li);
    });
    lista.style.display = data.length > 0 ? 'block' : 'none';
});

async function seleccionarEquipo(equipo) {
    document.getElementById('buscarEquipo').value = equipo.nombreEquipo;
    document.getElementById('equipoSeleccionadoId').value = equipo.id;
    document.getElementById('resultadosEquipo').style.display = 'none';

    const res = await fetch(`/Evaluacion/ObtenerIntegrantesEquipo?equipoId=${equipo.id}`);
    const data = await res.json();
    const lista = document.getElementById('listaIntegrantes');
    lista.innerHTML = '';
    data.forEach(i => {
        const div = document.createElement('div');
        div.className = 'integrante-item';
        div.textContent = `${i.nombreCompleto} - ${i.matricula}${i.esCreador ? ' (Creador)' : ''}`;
        lista.appendChild(div);
    });
    document.getElementById('integrantesEquipo').style.display = 'block';
}

function limpiarIntegrantes() {
    document.getElementById('equipoSeleccionadoId').value = '';
    document.getElementById('integrantesEquipo').style.display = 'none';
    document.getElementById('listaIntegrantes').innerHTML = '';
}

document.getElementById('mainForm').addEventListener('submit', function(e) {
    if (!document.getElementById('equipoSeleccionadoId').value) {
        e.preventDefault();
        document.getElementById('equipo-tab').click();
        document.getElementById('buscarEquipo').focus();
        alert('Selecciona un equipo antes de guardar.');
        return;
    }
    if (!this.checkValidity()) {
        e.preventDefault();
        const firstInvalid = this.querySelector(':invalid');
        if (firstInvalid) {
            const tabPane = firstInvalid.closest('.tab-pane');
            const tabButton = document.querySelector('button[data-bs-target="#' + tabPane.id + '"]');
            if (tabButton) tabButton.click();
            setTimeout(() => firstInvalid.reportValidity(), 150);
        }
    }
});

function toggleBonus(chk) {
    let area = chk.parentElement.querySelector('.bonus-area');
    if (chk.checked) area.classList.remove('d-none');
    else { area.classList.add('d-none'); area.querySelector('input').checked = false; calcBonus(); }
}
function calcBonus() { document.getElementById('BonusTotal').value = document.querySelectorAll('.bonus-check:checked').length; }
</script>
