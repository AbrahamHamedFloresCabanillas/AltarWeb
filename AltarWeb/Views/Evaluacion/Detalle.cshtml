@model AltarWeb.Models.Evaluacion
@{
    Layout = "_Layout";
    var integrantesEquipo = Model.Equipo?.Integrantes?.OrderByDescending(i => i.EsCreador).ThenBy(i => i.Alumno.NombreCompleto).ToList();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3 p-3 rounded panel-dark" style="border-bottom: 2px solid var(--color-secundario);">
        <div>
            <h2 class="text-white m-0"><i class="fa-solid fa-magnifying-glass me-2 text-warning"></i>Consulta de Evaluacion</h2>
            <div class="mt-1 text-secondary small">
                Periodo: <b class="text-white">@(string.IsNullOrEmpty(Model.Periodo) ? "N/A" : Model.Periodo)</b>
                <span class="ms-3">Juez: <b class="text-white">@(Model.Juez?.Usuario ?? Model.NombreJuez ?? "N/A")</b></span>
            </div>
        </div>
        <a href="/Home/Historial" class="btn btn-danger rounded-0 px-4 fw-bold">Regresar</a>
    </div>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-info text-center fw-bold rounded-0">@ViewBag.Mensaje</div>
    }

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="panel-dark p-4 rounded h-100">
                <h4 class="text-white border-bottom border-secondary pb-2">Equipo</h4>
                <label class="text-secondary small">Nombre del equipo</label>
                <input value="@Model.ObtenerNombreEquipo()" class="form-control form-control-dark mb-3" readonly />

                <h6 class="text-secondary">Integrantes</h6>
                <div class="table-responsive">
                    <table class="table-theme w-100">
                        <thead><tr><th>Nombre</th><th>Matricula</th><th>Correo</th></tr></thead>
                        <tbody>
                        @if (integrantesEquipo != null && integrantesEquipo.Any())
                        {
                            foreach (var item in integrantesEquipo)
                            {
                                <tr>
                                    <td class="text-white">@item.Alumno.NombreCompleto @(item.EsCreador ? "(Creador)" : "")</td>
                                    <td class="text-silver">@item.Alumno.Matricula</td>
                                    <td class="text-silver">@item.Alumno.CorreoElectronico</td>
                                </tr>
                            }
                        }
                        else
                        {
                            foreach (var item in Model.Integrantes)
                            {
                                <tr>
                                    <td class="text-white">@item.Nombre</td>
                                    <td class="text-silver">@item.Matricula</td>
                                    <td class="text-silver">@item.Correo</td>
                                </tr>
                            }
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="panel-dark p-4 rounded h-100">
                <h4 class="text-white border-bottom border-secondary pb-2">Evaluacion</h4>
                <div class="row g-3">
                    <div class="col-md-6"><label class="text-secondary small">Difunto</label><input value="@Model.NombreDifunto" class="form-control form-control-dark" readonly /></div>
                    <div class="col-md-3"><label class="text-secondary small">Niveles</label><input value="@Model.Niveles" class="form-control form-control-dark" readonly /></div>
                    <div class="col-md-3"><label class="text-secondary small">Tipo</label><input value="@Model.TipoAltar" class="form-control form-control-dark" readonly /></div>
                    <div class="col-12"><label class="text-secondary small">Hobbies / Tematica</label><textarea class="form-control form-control-dark" rows="4" readonly>@Model.Hobbies</textarea></div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-4"><div class="p-3 bg-dark rounded text-center"><div class="text-secondary small">Tradicion final</div><div class="fs-3 text-white">@Model.NotaTradicionFinal.ToString("F1")</div></div></div>
                    <div class="col-md-4"><div class="p-3 bg-dark rounded text-center"><div class="text-secondary small">Personalizacion final</div><div class="fs-3 text-white">@Model.NotaPersonalizacionFinal.ToString("F1")</div></div></div>
                    <div class="col-md-4"><div class="p-3 bg-dark rounded text-center"><div class="text-secondary small">Estetica</div><div class="fs-3 text-white">@Model.NotaEstetica.ToString("F1")</div></div></div>
                </div>

                <div class="p-4 text-center shadow mt-4 score-callout">
                    <h2 class="m-0 fw-bold"><i class="fa-solid fa-award me-2"></i>NOTA FINAL: @Model.NotaFinal.ToString("F1") / 10</h2>
                </div>

                <div class="d-flex flex-wrap gap-2 mt-4">
                    <a href="/Evaluacion/DescargarGrupal/@Model.Id" class="btn btn-outline-primary">Descargar Constancia Grupal</a>
                    @if (Model.EquipoId != null)
                    {
                        <a href="/Evaluacion/DescargarIndividuales/@Model.Id" class="btn btn-outline-secondary">Descargar Constancias Individuales (ZIP)</a>
                        <form method="post" action="/Evaluacion/EnviarConstancias/@Model.Id" class="d-inline">
                            <button type="submit" class="btn btn-success" onclick="return confirm('Enviar constancias por correo?')">Enviar Constancias por Correo</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
