@model AltarWeb.Models.Evaluacion
@{
    Layout = "_Layout";
}

<style>
    .app-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        padding: 20px;
        box-sizing: border-box;
    }

    .panel-principal {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        background-color: var(--color-superficie);
        border: 1px solid var(--color-borde);
        overflow: hidden;
        position: relative;
    }

    .tabs-header {
        background-color: var(--color-fondo);
        padding: 10px 20px 0 20px;
        border-bottom: 1px solid var(--color-borde);
        flex-shrink: 0;
    }

    .tab-content {
        position: relative;
        flex-grow: 1;
        height: 100%;
        overflow: hidden;
    }

    .tab-pane {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        padding: 20px;
        overflow: hidden;
        display: none;
        flex-direction: column;
    }

    .tab-pane.active {
        display: flex !important;
    }

    .dgv-wrapper {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        border: 1px solid var(--color-borde);
        background-color: var(--color-fondo);
        overflow: hidden;
    }

    .dgv-header {
        background-color: var(--color-superficie);
        color: var(--color-texto-secundario);
        font-weight: bold;
        padding: 10px;
        border-bottom: 1px solid var(--color-borde);
        display: flex;
    }

    .dgv-body {
        flex-grow: 1;
        overflow-y: auto;
    }

    .dgv-row {
        border-bottom: 1px solid var(--color-borde);
        display: flex;
    }

    .dgv-cell {
        padding: 10px;
        color: var(--color-texto-principal);
    }
</style>

<div class="app-container">
    <div class="d-flex justify-content-between align-items-center mb-3 p-3 rounded panel-dark flex-shrink-0" style="border-bottom: 2px solid var(--color-secundario);">
        <h2 class="text-white m-0"><i class="fa-solid fa-magnifying-glass me-2 text-warning"></i>Consulta de Evaluación</h2>
        <a href="/Home/Historial" class="btn btn-danger rounded-0 px-4 fw-bold">
            <i class="fa-solid fa-arrow-left me-1"></i> REGRESAR
        </a>
    </div>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-success text-center fw-bold m-0 rounded-0">
            <i class="fa-solid fa-circle-check me-2"></i>@ViewBag.Mensaje
        </div>
    }

    <div class="panel-principal">
        <div class="tabs-header">
            <ul class="nav nav-tabs" id="myTab" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active" id="equipo-tab" data-bs-toggle="tab" data-bs-target="#equipo">
                        <i class="fa-solid fa-users me-1"></i> 1. Datos del Equipo
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link" id="altar-tab" data-bs-toggle="tab" data-bs-target="#altar">
                        <i class="fa-solid fa-star me-1"></i> 2. Evaluación de Altar
                    </button>
                </li>
            </ul>
        </div>

        <div class="tab-content" id="myTabContent">
            <div class="tab-pane fade show active" id="equipo">
                <div class="mb-3 flex-shrink-0">
                    <label class="lbl-form text-orange fw-bold mb-1">Nombre del Equipo:</label>
                    <input value="@Model.NombreEquipo" class="form-control form-control-dark rounded-0" style="max-width: 500px; font-weight: bold; font-size: 1.2rem;" readonly />
                </div>
                <label class="text-secondary mb-1 flex-shrink-0">Lista de Integrantes:</label>
                <div class="dgv-wrapper">
                    <div class="dgv-header">
                        <div style="width: 40%;"><i class="fa-solid fa-user me-2"></i>Nombre Completo</div>
                        <div style="width: 20%; padding-left: 10px; border-left: 1px solid var(--color-borde);"><i class="fa-solid fa-id-card me-2"></i>Matrícula</div>
                        <div style="width: 40%; padding-left: 10px; border-left: 1px solid var(--color-borde);"><i class="fa-solid fa-envelope me-2"></i>Correo</div>
                    </div>
                    <div class="dgv-body">
                        @foreach (var intg in Model.Integrantes)
                        {
                            <div class="dgv-row">
                                <div class="dgv-cell" style="width: 40%;">@intg.Nombre</div>
                                <div class="dgv-cell" style="width: 20%; border-left: 1px solid var(--color-borde);">@intg.Matricula</div>
                                <div class="dgv-cell" style="width: 40%; border-left: 1px solid var(--color-borde);">@intg.Correo</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="altar">
                <div class="row h-100 g-0">
                    <div class="col-md-5 d-flex flex-column h-100 border-end border-secondary pe-3">
                        <div style="flex-grow: 1; overflow-y: auto; padding-right: 5px;">
                            <h5 class="text-white border-bottom border-secondary pb-2 mb-3"><i class="fa-solid fa-list-check me-2"></i>Datos Generales</h5>
                            <label class="text-secondary small">Difunto:</label> <input value="@Model.NombreDifunto" class="form-control form-control-dark mb-2" readonly />
                            <label class="text-secondary small">Niveles:</label> <input value="@Model.Niveles" class="form-control form-control-dark mb-2" readonly />
                            <label class="text-secondary small">Tipo:</label> <input value="@Model.TipoAltar" class="form-control form-control-dark mb-4" readonly />
                            <h5 class="text-white border-bottom border-secondary pb-2 mb-2"><i class="fa-solid fa-check-double me-2"></i>Checklist Realizado</h5>
                            <div class="p-3 mb-3 panel-dark rounded">
                                @{
                                    void RenderCheck(string l, bool v)
                                    {
                                        <div class="form-check mb-1">
                                            <input class="form-check-input bg-secondary border-0" type="checkbox" checked="@v" disabled>
                                            <label class="form-check-label text-silver">@l</label>
                                        </div>
                                    }
                                }
                                @{
                                    RenderCheck("Foto", Model.ChkFoto); RenderCheck("Velas", Model.ChkVelas); RenderCheck("Flor", Model.ChkFlor); RenderCheck("Papel", Model.ChkPapel); RenderCheck("Pan", Model.ChkPan);
                                    RenderCheck("Agua", Model.ChkAgua); RenderCheck("Sal", Model.ChkSal); RenderCheck("Incienso", Model.ChkIncienso); RenderCheck("Calaveritas", Model.ChkCalaveritas); RenderCheck("Objetos", Model.ChkObjetos);
                                }
                                <div class="mt-3 pt-2 border-top border-secondary text-orange small"><i class="fa-solid fa-plus me-1"></i> Bonus Detectados: @Model.BonusTematicos</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7 d-flex flex-column h-100 ps-4">
                        <h5 class="text-white border-bottom border-secondary pb-2 mb-3 flex-shrink-0"><i class="fa-solid fa-square-poll-vertical me-2"></i>Resultados</h5>
                        <label class="text-secondary small flex-shrink-0">Hobbies:</label> <textarea class="form-control form-control-dark mb-3" style="flex-grow: 1; resize: none;" readonly>@Model.Hobbies</textarea>
                        <div class="flex-shrink-0">
                            <div class="row mb-2"><div class="col-5"><label class="text-secondary">Tradición:</label></div><div class="col-7"><input value="@Model.NotaTradicion" class="form-control form-control-dark text-center" readonly /></div></div>
                            <div class="row mb-2"><div class="col-5"><label class="text-orange fw-bold">Personalización:</label></div><div class="col-7"><input value="@Model.NotaPersonalizacion" class="form-control form-control-dark text-center" readonly /></div></div>
                            <div class="row mb-4"><div class="col-5"><label class="text-secondary">Estética:</label></div><div class="col-7"><input value="@Model.NotaEstetica" class="form-control form-control-dark text-center" readonly /></div></div>
                            <div class="p-4 text-center rounded shadow" style="background-color: var(--color-primario); color: white;">
                                <h2 class="m-0 fw-bold"><i class="fa-solid fa-award me-2"></i>NOTA FINAL: @Model.NotaFinal.ToString("F1") / 10</h2>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>