@model IEnumerable<AltarWeb.Models.Alumno>
@{
    Layout = "_Layout";
    var equipos = ViewBag.EquiposActuales as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded panel-dark" style="border-bottom:2px solid var(--color-secundario);">
        <h2 class="text-white m-0"><i class="fa-solid fa-user-graduate me-2 text-warning"></i>Gestion de Alumnos</h2>
        <a href="/Home/Menu" class="btn btn-danger">Regresar</a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success rounded-0 fw-bold text-center">@TempData["Mensaje"]</div>
    }

    <div class="panel-dark p-4 rounded">
        <input id="buscarAlumnoAdmin" class="form-control form-control-dark mb-3" placeholder="Buscar por nombre o matricula..." autocomplete="off" />
        <table class="table-theme w-100">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Matricula</th>
                    <th>Correo</th>
                    <th>Proveedor</th>
                    <th>Equipo actual</th>
                    <th>Estado</th>
                    <th>Accion</th>
                </tr>
            </thead>
            <tbody id="tablaAlumnos">
                @foreach (var alumno in Model)
                {
                    <tr data-busqueda="@($"{alumno.NombreCompleto} {alumno.Matricula}".ToLower())">
                        <td class="text-white">@alumno.NombreCompleto</td>
                        <td class="text-silver">@alumno.Matricula</td>
                        <td class="text-silver">@alumno.CorreoElectronico</td>
                        <td><span class="badge bg-secondary">@alumno.ProveedorAuth</span></td>
                        <td class="text-silver">@(equipos.TryGetValue(alumno.Id, out var eq) ? eq : "Sin equipo")</td>
                        <td>@(alumno.Activo ? Html.Raw("<span class=\"badge bg-success\">Activo</span>") : Html.Raw("<span class=\"badge bg-danger\">Inactivo</span>"))</td>
                        <td>
                            @if (alumno.Activo)
                            {
                                <form method="post" action="/Admin/DesactivarAlumno/@alumno.Id" class="d-inline">
                                    <button class="btn btn-dark btn-sm" onclick="return confirm('Desactivar alumno?')">Desactivar</button>
                                </form>
                            }
                            else
                            {
                                <form method="post" action="/Admin/ReactivarAlumno/@alumno.Id" class="d-inline">
                                    <button class="btn btn-success btn-sm">Reactivar</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
document.getElementById('buscarAlumnoAdmin').addEventListener('input', function () {
    const q = this.value.trim().toLowerCase();
    document.querySelectorAll('#tablaAlumnos tr').forEach(row => {
        row.style.display = !q || row.dataset.busqueda.includes(q) ? '' : 'none';
    });
});
</script>
