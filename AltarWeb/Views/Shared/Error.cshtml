@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container py-5">
    <div class="panel-dark p-5 rounded text-center">
        <div class="display-4 text-danger mb-3"><i class="fa-solid fa-triangle-exclamation"></i></div>
        <h1 class="text-white mb-3">Ocurrio un error</h1>
        <p class="text-secondary mb-4">No se pudo completar la solicitud. Intenta regresar a la pantalla anterior o al menu principal.</p>

        @if (Model.ShowRequestId)
        {
            <p class="text-secondary small">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </p>
        }

        <a href="/Home/Menu" class="btn btn-primary">Volver al menu</a>
    </div>
</div>
