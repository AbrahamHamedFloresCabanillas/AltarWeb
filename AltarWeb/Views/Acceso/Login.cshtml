@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Login - Juez de Altares</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
</head>
<body class="d-flex align-items-center justify-content-center" style="height: 100vh;">
    <div class="panel-dark shadow-lg" style="width: 400px; padding: 40px;">
        <h2 class="text-center text-orange fw-bold mb-4">ACCESO JUECES</h2>

        <form method="post" action="/Acceso/Login">
            <div class="mb-3">
                <label class="lbl-form">Usuario:</label>
                <input type="text" name="usuario" class="form-control form-control-dark" required />
            </div>
            <div class="mb-4">
                <label class="lbl-form">Contraseña:</label>
                <input type="password" name="password" class="form-control form-control-dark" required />
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-1 mb-3 text-center small">@ViewBag.Error</div>
            }

            <button type="submit" class="btn btn-purple btn-flat w-100 fs-5">INICIAR SESIÓN</button>
        </form>
    </div>
</body>
</html>